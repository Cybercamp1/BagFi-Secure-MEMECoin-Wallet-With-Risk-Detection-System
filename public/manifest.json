{
  "manifest_version": 3,
  "name": "BagFi Wallet",
  "version": "1.0",
  "description": "BagFi Wallet - Next-Gen Memecoin Trading Terminal",
  "action": {
    "default_popup": "index.html",
    "default_icon": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["provider.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
